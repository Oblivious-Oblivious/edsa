{
  "$schema": "https://raw.githubusercontent.com/Oblivious-Oblivious/Emeralds/master/schema/em.schema.json",
  "author": "",
  "name": "edsa",
  "version": "0.1.0",
  "license": "gpl-v3",
  "locignore": {
    "extensions": [],
    "directories": ["libs", "spec/table/examples"]
  },
  "lintignore": {
    "extensions": [],
    "directories": ["libs", "src/hash/xxh3/xxh3_implementation.h"]
  },
  "scripts": {
    "test-table": [
      "clang -O3 -ffast-math -std=c2x -Wall -Wextra -Werror -pedantic -pedantic-errors -Wpedantic src/vector/*.c src/string/*.c src/file-handler/*.c src/table/*.c edsa.table.spec.c -o spec_results",
      "./spec_results",
      "rm spec_results"
    ]
  },
  "compile-flags": {
    "darwin": {
      "cc": "clang",
      "debug": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "-g -fsanitize=address",
        "warnings": "-Wall -Wextra -Werror -pedantic -pedantic-errors -Wpedantic"
      },
      "release": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "",
        "warnings": ""
      }
    },
    "linux": {
      "cc": "gcc",
      "debug": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "-g",
        "warnings": "-Wall -Wextra -Werror -pedantic -pedantic-errors -Wpedantic"
      },
      "release": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "",
        "warnings": ""
      }
    },
    "win32": {
      "cc": "gcc",
      "debug": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "-g",
        "warnings": "-Wall -Wextra -Werror -pedantic -pedantic-errors -Wpedantic"
      },
      "release": {
        "opt": "-O2",
        "version": "-std=c89",
        "flags": "",
        "warnings": ""
      }
    }
  },
  "dependencies": {},
  "dev-dependencies": {
    "https://github.com/Oblivious-Oblivious/cSpec": "latest"
  }
}
